# ========================================
# 덴트웹 브릿지 에이전트 설정
# ========================================

# 덴트웹 MS SQL Server 설정
DENTWEB_DB_SERVER=localhost
DENTWEB_DB_PORT=1433
DENTWEB_DB_DATABASE=DENTWEBDB

# 인증 방식: windows (기본, 비밀번호 불필요) 또는 sql
DENTWEB_DB_AUTH=windows

# SQL 인증 시에만 필요 (Windows 인증이면 비워두세요)
DENTWEB_DB_USER=
DENTWEB_DB_PASSWORD=

# Supabase API 설정 (웹 대시보드 > 리콜 설정 > 덴트웹 탭에서 복사)
SUPABASE_URL=https://beahjntkmkfhpcbhfnrr.supabase.co
CLINIC_ID=your-clinic-uuid
API_KEY=dw_your_api_key_here

# 동기화 설정
SYNC_INTERVAL_SECONDS=300
SYNC_TYPE=incremental

# 데모 모드 (MS SQL Server 없이 모의 데이터로 테스트)
DEMO_MODE=false
DEMO_PATIENT_COUNT=10
