# ==========================================
# ai-suggestion-worker 환경변수
# ==========================================

# --- 필수 ---

# Supabase 프로젝트 URL
SUPABASE_URL=https://beahjntkmkfhpcbhfnrr.supabase.co

# Supabase service_role 키 (RLS 우회용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API 키 (Claude Agent SDK용)
ANTHROPIC_API_KEY=

# 마스터 체크아웃 레포 경로 (git worktree add 기준)
# 예: /Users/hhs/Project/dental-clinic-manager/dental-clinic-manager
REPO_PATH=/Users/hhs/Project/dental-clinic-manager/dental-clinic-manager

# worktree들이 생성될 상위 디렉토리
# 예: /Users/hhs/Project/dental-clinic-manager/worktrees
WORKTREE_ROOT=/Users/hhs/Project/dental-clinic-manager/worktrees

# GitHub Personal Access Token (gh CLI가 이 값을 읽어서 PR 생성)
GITHUB_TOKEN=

# --- 선택 ---

# 빌드 실패 시 Claude에게 재요청할 최대 횟수 (기본 3)
MAX_BUILD_RETRIES=3

# 태스크 하나의 타임아웃 (ms, 기본 1800000 = 30분)
TASK_TIMEOUT_MS=1800000

# 사용할 Claude 모델 (기본 claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-5
