{
  "name": "hayan-marketing-worker",
  "version": "1.1.0",
  "description": "하얀치과 마케팅 워커 - Electron 데스크탑 앱",
  "productName": "클리닉 매니저 워커",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/huisu-hwang/dental-clinic-manager.git"
  },
  "author": "하얀치과",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && npm run bundle:scheduler && electron dist/main.js",
    "build": "tsc && npm run bundle:scheduler",
    "build:win": "tsc && npm run bundle:scheduler && electron-builder --win",
    "build:mac": "tsc && npm run bundle:scheduler && electron-builder --mac",
    "bundle:scheduler": "node scripts/bundle-scheduler.js",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0",
    "mssql": "^11.0.1",
    "playwright": "^1.50.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
