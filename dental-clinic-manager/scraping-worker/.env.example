# Supabase
SUPABASE_URL=https://beahjntkmkfhpcbhfnrr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 암호화 키 (32바이트 hex, Next.js 앱과 동일해야 함)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# 워커 설정
WORKER_ID=worker-macmini-01
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_MAX_CONCURRENT=3

# 스크래핑 모드: playwright (기본, 브라우저) | protocol (HTTP 직접 호출)
SCRAPING_MODE=playwright

# Playwright (SCRAPING_MODE=playwright일 때)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# Protocol (SCRAPING_MODE=protocol일 때)
PROTOCOL_TIMEOUT_MS=30000

# 배치 스케줄 (cron 표현식)
DAILY_SYNC_CRON=0 7 * * *
MONTHLY_SETTLEMENT_CRON=0 8 1 * *
CLINIC_INTERVAL_MINUTES=5

# 로깅
LOG_LEVEL=info
