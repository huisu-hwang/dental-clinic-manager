# ==========================================
# ai-suggestion-channel 환경변수
# ==========================================

# --- 필수 ---

# Supabase 프로젝트 URL
SUPABASE_URL=https://beahjntkmkfhpcbhfnrr.supabase.co

# Supabase service_role 키 (community_posts 조회용, RLS 우회)
SUPABASE_SERVICE_ROLE_KEY=

# --- 선택 ---

# HTTP 리스너 포트 (기본 8788, Hookdeck CLI가 이 포트로 포워드)
CHANNEL_PORT=8788

# Supabase Database Webhook에서 보내는 X-Webhook-Secret 값 검증 (공백이면 검증 스킵)
# Hookdeck가 중간에 있어 이미 1차 인증되지만, 다중 방어로 설정 권장
WEBHOOK_SECRET=
